#!/usr/bin/env php
<?php

declare(strict_types=1);

$container = require __DIR__ . '/../../../../bootstrapCli.php';

$argc = $_SERVER['argc'];
$argv = $_SERVER['argv'];

echo PHP_EOL;

if ($argc != 2) {
    echo 'Please provide directory relative to ' . __ROOT__ . PHP_EOL . PHP_EOL;
    exit(1);
}

$main = new Main();
$main->run(__ROOT__ . DIRECTORY_SEPARATOR . trim(trim($argv[1]), '/'));

class Main
{
    protected string $matches = '/views/';

    public function run(string $path): void
    {
        if (!$path = realpath($path)) {
            $this->error('Can not locate ' . $path);
        }

        echo 'Searching ' . $path . PHP_EOL;

        $lines = [];

        $q = "'";

        $phpFiles = $this->rglob($path . '/', '*.php');

        foreach ($phpFiles as $absPath) {
            $directoryPos = strpos($absPath, $this->matches);

            if ($directoryPos > 0) {
                $name = substr($absPath, $directoryPos + 1);
                $key = substr($name, strlen($this->matches) - 1, -4);

                $lines[] =   $q . $key . $q . ' => ' . '__ROOT__ . ' . $q . substr($absPath, strlen(__ROOT__)) . $q . ',';
            }
        }

        $this->displayOutput($lines);
    }

    protected function displayOutput(array $lines): void
    {
        if (count($lines) == 0) {
            $this->error('No Views found.');
        }

        echo 'Found Views Pathes:' . PHP_EOL;
        echo PHP_EOL . implode(PHP_EOL, $lines) . PHP_EOL . PHP_EOL;
    }

    protected function rglob(string $path = '', string $pattern = '*', int $flags = 0): array
    {
        $files = glob($path . $pattern, $flags) ?: [];

        foreach (glob($path . '*', GLOB_MARK | GLOB_ONLYDIR | GLOB_NOSORT) ?: [] as $dir) {
            array_push($files, ...$this->rglob($dir, $pattern, $flags));
        }

        return $files;
    }

    protected function error(string $msg): void
    {
        echo $msg . PHP_EOL . PHP_EOL;
        exit(1);
    }
}
