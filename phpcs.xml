<?xml version="1.0"?>
<ruleset name="orange-framework">
    <description>Coding standard for the Orange Framework core package.</description>

    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg value="np"/>

    <file>src</file>

    <rule ref="PSR12">
        <!-- Drop PSR-12 §2.3's 120-character soft line-length limit; every other
             PSR-12 sniff still applies. -->
        <exclude name="Generic.Files.LineLength.TooLong"/>
    </rule>

</ruleset>
